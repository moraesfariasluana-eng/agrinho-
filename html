const game = document.getElementById("game");

function renderizarPasso(id) {
  const passo = passos.find((p) => p.id === id);

  game.innerHTML = `
    <div class="passo">
      ${
        passo.imagem
          ? `<img src="${passo.imagem}" alt="Imagem da aventura" width="100%">`
          : ""
      }

      ${passo.titulo ? `<h1>${passo.titulo}</h1>` : ""}

      <p>${passo.texto}</p>

      <div class="botoes">
        ${passo.botoes
          .map(
            (botao) => `
          <button onclick="renderizarPasso(${botao.proximo})">
            ${botao.texto}
          </button>
        `
          )
          .join("")}
      </div>
    </div>
  `;
}

renderizarPasso(0);
